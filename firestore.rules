rules_version = '2';

// User profiles are written only by the FastAPI backend (Firebase Admin SDK).
// Clients may read their own document for dashboard/offline UI.

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
